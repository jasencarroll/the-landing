---
import '../styles/global.css'
import { CommandPalette } from '@/components/CommandPalette'
import { CursorGlow } from '@/components/CursorGlow'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Jasen Carroll',
  description = 'Software engineer with 12 years in FDA-regulated manufacturing building tools for MedTech, compliance, and quality teams.',
} = Astro.props
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | jasencarroll.com`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://jasencarroll.com" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | jasencarroll.com</title>
  </head>
  <body class="min-h-screen bg-background text-foreground font-mono antialiased">
    <CursorGlow client:load />

    <nav class="fixed top-0 left-0 right-0 z-30 border-b border-border bg-background/80 backdrop-blur-sm">
      <div class="max-w-4xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-sm font-bold tracking-widest hover:text-primary transition-colors uppercase">
          JC
        </a>
        <div class="flex gap-8 text-xs text-muted tracking-wider">
          <a href="/about" class="hover:text-foreground transition-colors">about</a>
          <a href="/projects" class="hover:text-foreground transition-colors">projects</a>
          <a href="/resume" class="hover:text-foreground transition-colors">resume</a>
          <a href="/contact" class="hover:text-foreground transition-colors">contact</a>
        </div>
      </div>
    </nav>

    <main class="relative z-10 pt-16">
      <slot />
    </main>

    <CommandPalette client:load />
  </body>
</html>
