---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Jasen Carroll">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-6">
    <div class="max-w-4xl w-full">

      <p class="text-xs text-muted tracking-widest uppercase mb-6">Philadelphia, PA — Open to MedTech &amp; FDA software roles</p>

      <h1 class="text-6xl md:text-8xl font-bold tracking-wider uppercase mb-6 leading-none">
        Jasen Carroll
      </h1>

      <p class="text-base md:text-lg text-muted max-w-2xl mb-12 leading-relaxed">
        Software engineer with 12 years in FDA-regulated manufacturing. I build tools for quality teams, compliance programs, and regulated systems — because I've been on the other side of the software those teams depend on.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/projects"
          class="px-8 py-4 border-2 border-foreground text-foreground text-sm tracking-wider hover:border-primary hover:bg-primary/10 transition-all duration-200"
        >
          Projects
        </a>
        <a
          href="/about"
          class="px-8 py-4 border-2 border-border text-muted text-sm tracking-wider hover:border-foreground hover:text-foreground transition-all duration-200"
        >
          About
        </a>
      </div>

    </div>
  </div>
</Layout>
