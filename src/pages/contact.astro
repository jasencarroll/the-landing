---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Contact" description="Get in touch with Jasen Carroll.">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-6">
    <div class="max-w-4xl w-full">

      <p class="text-xs text-muted tracking-widest uppercase mb-4">Contact</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-wider uppercase mb-6">
        Get in Touch
      </h1>
      <p class="text-muted text-sm leading-relaxed mb-12 max-w-md">
        The best way to reach me is LinkedIn. I'm open to MedTech companies, FDA software vendors, eQMS platforms, and compliance tooling roles.
      </p>

      <a
        href="https://linkedin.com/in/jasenc"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex px-8 py-4 border-2 border-foreground text-foreground text-sm tracking-wider hover:border-primary hover:bg-primary/10 transition-all duration-200"
      >
        Connect on LinkedIn ↗
      </a>

    </div>
  </div>
</Layout>
