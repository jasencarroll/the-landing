---
import Layout from '@/layouts/Layout.astro'
import { Badge } from '@/components/ui/badge'

const projects = [
  {
    name: 'Bun Stack',
    desc: 'CLI scaffolding tool for full-stack Bun + TypeScript apps. Rails-inspired conventions, zero-config Railway deploy. 10 stars on GitHub.',
    tags: ['TypeScript', 'Bun', 'CLI', 'React'],
    href: 'https://github.com/jasencarroll/create-bun-stack',
    live: 'https://bun-stack.jasenc.dev',
  },
  {
    name: 'Specz',
    desc: 'Conversational AI tool for generating software specifications through guided interviews. Structured intake, documented outputs, traceable decisions — mirrors how validation planning works.',
    tags: ['SvelteKit', 'TypeScript', 'AI', 'Claude'],
    href: 'https://github.com/jasencarroll/specz',
  },
  {
    name: 'Axiomlayer',
    desc: 'Personal AI infrastructure stack: Docker, Tailscale, Ollama, Open WebUI, n8n workflow automation, Wake-on-LAN GPU inference. Self-hosted, cost-optimized.',
    tags: ['Python', 'Docker', 'Tailscale', 'Ollama'],
    href: 'https://github.com/jasencarroll/axiomlayer',
  },
  {
    name: 'Self-Hosted Language Models',
    desc: 'Bare metal LLM deployment on Ubuntu using Open WebUI and Ollama. Custom APIs for inference, 60%+ cost reduction vs. cloud. Secured over Tailscale VPN.',
    tags: ['Python', 'Ollama', 'Ubuntu', 'Infrastructure'],
    href: 'https://github.com/jasencarroll/axiomlayer',
  },
]
---

<Layout title="Projects" description="Projects by Jasen Carroll — compliance tooling, infrastructure, and software engineering.">
  <div class="max-w-4xl mx-auto px-6 py-20">

    <p class="text-xs text-muted tracking-widest uppercase mb-4">Projects</p>
    <h1 class="text-4xl md:text-5xl font-bold tracking-wider uppercase mb-12">What I Build</h1>

    <div class="space-y-px">
      {projects.map((p) => (
        <div class="border border-border p-6 hover:border-primary/50 hover:bg-card transition-all duration-200 group">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h2 class="text-base font-bold tracking-wider group-hover:text-primary transition-colors">{p.name}</h2>
            <div class="flex gap-3 shrink-0">
              {p.live && (
                <a href={p.live} target="_blank" rel="noopener noreferrer" class="text-xs text-muted hover:text-foreground tracking-wider transition-colors">
                  live ↗
                </a>
              )}
              <a href={p.href} target="_blank" rel="noopener noreferrer" class="text-xs text-muted hover:text-foreground tracking-wider transition-colors">
                github ↗
              </a>
            </div>
          </div>
          <p class="text-sm text-muted leading-relaxed mb-4">{p.desc}</p>
          <div class="flex flex-wrap gap-2">
            {p.tags.map(tag => <Badge client:load>{tag}</Badge>)}
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>
